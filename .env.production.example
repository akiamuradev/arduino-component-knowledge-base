# Copy to .env.production outside Git and replace every replace-with-* value.
# Never commit the resulting file or TLS private keys.
ACKB_POSTGRES_DB=ackb
ACKB_POSTGRES_USER=ackb
ACKB_POSTGRES_PASSWORD=replace-with-production-postgres-password
ACKB_MINIO_ROOT_USER=replace-with-production-minio-user
ACKB_MINIO_ROOT_PASSWORD=replace-with-production-minio-password
ACKB_AUTH_THROTTLE_PEPPER=replace-with-at-least-32-random-characters
ACKB_INTERNAL_HOSTNAME=replace-with-internal-dns-name
ACKB_BIND_ADDRESS=replace-with-static-ip
ACKB_EDGE_TLS_CERT_FILE=replace-with-absolute-edge-certificate-path
ACKB_EDGE_TLS_KEY_FILE=replace-with-absolute-edge-private-key-path
ACKB_MINIO_TLS_CERT_FILE=replace-with-absolute-minio-certificate-path
ACKB_MINIO_TLS_KEY_FILE=replace-with-absolute-minio-private-key-path
ACKB_CA_BUNDLE_FILE=replace-with-absolute-ca-bundle-path
ACKB_FFPROBE_TIMEOUT_SECONDS=15
ACKB_FFMPEG_TIMEOUT_SECONDS=900
ACKB_FFMPEG_THREADS=2
ACKB_MEDIA_JOB_MAX_ATTEMPTS=4
ACKB_MEDIA_JOB_LEASE_SECONDS=1800
ACKB_IMPORT_JOB_MAX_ATTEMPTS=4
ACKB_IMPORT_LOCK_TTL_SECONDS=60
ACKB_IMPORT_LOCK_WAIT_SECONDS=10
ACKB_LOG_LEVEL=INFO
ACKB_DOCS_ENABLED=false
ACKB_APP_VERSION=0.20.0
ACKB_COMMIT_SHA=replace-with-deployed-commit-sha
ACKB_BUILD_DATE=replace-with-ISO-8601-build-date
