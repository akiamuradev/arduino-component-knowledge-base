(kicad_symbol_lib
  (version 20231120)
  (symbol "BME280"
    (property "Reference" "U")
    (property "Value" "BME280")
    (property "Aliases" "BME280-Sensor")
    (property "Description" "Digital humidity pressure and temperature sensor")
    (property "ki_keywords" "environmental humidity pressure temperature I2C SPI")
    (property "Manufacturer" "Bosch")
    (property "Datasheet" "https://www.bosch-sensortec.com/media/boschsensortec/downloads/datasheets/bst-bme280-ds002.pdf")
    (footprint_filters "LGA*2.5x2.5mm*")
    (pin power_in line (name "VDD") (number "1"))
    (pin bidirectional line (name "SDI") (number "3"))
    (pin input line (name "SCK") (number "4"))))
