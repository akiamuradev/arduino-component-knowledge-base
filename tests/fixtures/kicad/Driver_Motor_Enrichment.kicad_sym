(kicad_symbol_lib
  (version 20231120)
  (symbol "DRV8830"
    (property "Reference" "U")
    (property "Value" "DRV8830")
    (property "Aliases" "DRV8830DGQ, DRV8830DRC")
    (property "Description" "Low-voltage I2C brushed DC motor driver")
    (property "ki_keywords" "motor H-bridge I2C")
    (property "Manufacturer" "Texas Instruments")
    (property "Datasheet" "https://www.ti.com/lit/ds/symlink/drv8830.pdf")
    (footprint_filters "VSSOP*" "SON*")
    (pin power_in line (name "VCC") (number "1"))
    (pin input line (name "SCL") (number "2"))
    (pin bidirectional line (name "SDA") (number "3"))
    (pin output line (name "OUT1") (number "4")))
  (symbol "L298P"
    (property "Reference" "U")
    (property "Value" "L298P")
    (property "Description" "Dual full-bridge motor driver")
    (property "ki_keywords" "motor H-bridge")
    (property "Manufacturer_Name" "STMicroelectronics")
    (property "Datasheet" "https://www.st.com/resource/en/datasheet/l298.pdf")
    (footprint_filters "PowerSO20*")
    (pin power_in line (name "VS") (number "4"))
    (pin input line (name "IN1") (number "5"))
    (pin output line (name "OUT1") (number "2"))))
