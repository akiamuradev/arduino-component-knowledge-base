(kicad_symbol_lib
  (version 20231120)
  (symbol "SSD1306"
    (property "Reference" "U")
    (property "Value" "SSD1306")
    (property "Description" "128x64 OLED display controller")
    (property "ki_keywords" "OLED display I2C SPI")
    (property "Datasheet" "https://cdn-shop.adafruit.com/datasheets/SSD1306.pdf")
    (footprint_filters "SOIC*" "QFN*")
    (pin power_in line (name "VDD") (number "1"))
    (pin input line (name "SCL") (number "2"))
    (pin bidirectional line (name "SDA") (number "3"))
    (pin power_in line (name "VSS") (number "4"))))
