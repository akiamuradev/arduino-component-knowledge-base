(kicad_symbol_lib
  (version 20231120)
  (symbol "ATmega328P"
    (extends "ATmega8")
    (property "Reference" "U")
    (property "Value" "ATmega328P")
    (property "Description" "8-bit AVR microcontroller")
    (symbol "ATmega328P_1_1" (pin input line (name "RESET") (number "1")))
    (symbol "ATmega328P_2_1" (pin bidirectional line (name "PB0") (number "14")))))
