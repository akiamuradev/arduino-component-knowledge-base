(kicad_symbol_lib
  (version 20231120)
  (generator kicad_symbol_editor)
  (symbol "LM35"
    (property "Reference" "U")
    (property "Value" "LM35")
    (property "Description" "Precision centigrade temperature sensor")
    (property "ki_keywords" "temperature sensor analog")
    (property "Datasheet" "https://www.ti.com/lit/ds/symlink/lm35.pdf")
    (property "Footprint" "Package_TO_SOT_THT:TO-92_Inline")
    (footprint_filters "TO?92*")
    (symbol "LM35_1_1"
      (pin power_in line (name "V+") (number "1"))
      (pin output line (name "VOUT") (number "2"))
      (pin power_in line (name "GND") (number "3")))))
