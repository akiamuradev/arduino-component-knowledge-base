# Safe local placeholders only. Copy to .env and replace values outside Git.
ACKB_POSTGRES_DB=ackb
ACKB_POSTGRES_USER=ackb
ACKB_POSTGRES_PASSWORD=replace-with-local-postgres-password
ACKB_MINIO_ROOT_USER=replace-with-local-minio-user
ACKB_MINIO_ROOT_PASSWORD=replace-with-local-minio-password
ACKB_HTTP_PORT=8080
ACKB_ENVIRONMENT=local
ACKB_DATABASE_URL=postgresql+asyncpg://ackb:replace-with-local-password@127.0.0.1:5432/ackb
ACKB_AUTH_THROTTLE_PEPPER=replace-with-at-least-32-random-characters
ACKB_SESSION_COOKIE_SECURE=false
ACKB_REDIS_URL=redis://127.0.0.1:6379/0
ACKB_MINIO_ENDPOINT=127.0.0.1:9000
ACKB_MINIO_ACCESS_KEY=replace-with-local-access-key
ACKB_MINIO_SECRET_KEY=replace-with-local-secret-key
ACKB_MINIO_SECURE=false
ACKB_FFPROBE_PATH=ffprobe
ACKB_FFMPEG_PATH=ffmpeg
ACKB_FFPROBE_TIMEOUT_SECONDS=15
ACKB_FFMPEG_TIMEOUT_SECONDS=900
ACKB_FFMPEG_THREADS=2
ACKB_MEDIA_JOB_MAX_ATTEMPTS=4
ACKB_MEDIA_JOB_LEASE_SECONDS=1800
ACKB_MEDIA_GLOBAL_PENDING_UPLOAD_LIMIT=100
ACKB_MEDIA_RETENTION_GRACE_HOURS=24
ACKB_MEDIA_RETENTION_BATCH_SIZE=200
ACKB_MEDIA_RETENTION_SCAN_LIMIT=5000
ACKB_IMPORT_JOB_MAX_ATTEMPTS=4
ACKB_IMPORT_LOCK_TTL_SECONDS=60
ACKB_IMPORT_LOCK_WAIT_SECONDS=10
ACKB_IMPORT_PIPELINE_MODE=disabled
ACKB_IMPORT_PIPELINE_STAGE_TIMEOUT_SECONDS=15
ACKB_IMPORT_PIPELINE_SAFE_RETRY_ATTEMPTS=2
ACKB_KICAD_LIBRARY_ALLOWLIST=Sensor_,MCU_,Display_,74xx,Relay,Switch,Connector,Motor,Driver_Motor,Regulator_,Transistor_,Transistor_Array,Timer,Diode,LED,Memory,Interface_
# Temporary rollback switch for the deprecated KiCad-to-card path.
ACKB_LEGACY_KICAD_CARD_IMPORT_ENABLED=true
ACKB_REPOSITORY_CONNECT_TIMEOUT_SECONDS=5
ACKB_REPOSITORY_READ_TIMEOUT_SECONDS=20
ACKB_REPOSITORY_TOTAL_TIMEOUT_SECONDS=30
ACKB_REPOSITORY_MAX_RESPONSE_BYTES=8388608
ACKB_REPOSITORY_MAX_FILE_BYTES=2097152
ACKB_LOG_LEVEL=INFO
ACKB_DOCS_ENABLED=true
ACKB_APP_VERSION=0.21.0
ACKB_COMMIT_SHA=unknown
ACKB_BUILD_DATE=unknown
